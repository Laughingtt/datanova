# DataNova 环境配置
# 复制此文件为 .env 并填入实际值

# 加密密钥 (必须32字节，用于加密数据源密码)
DATANOVA_ENCRYPTION_KEY=datanova-default-key-32b!

# 数据目录 (默认: ./data)
# DATANOVA_DIR=./data

# Server 端口 (默认: 3000)
# PORT=3000

# LLM API Key — pi-ai 会自动从环境变量读取
# 只需设置对应 provider 的环境变量即可：
# - Anthropic: ANTHROPIC_API_KEY=sk-ant-...
# - OpenAI: OPENAI_API_KEY=sk-...
# - 其他 provider 见 pi-ai 文档
#
# 示例 (选择一个即可):
ANTHROPIC_API_KEY=sk-ant-your-key-here
# OPENAI_API_KEY=sk-your-openai-key

# 默认 LLM 配置 (可选)
# DATANOVA_PROVIDER=anthropic
# DATANOVA_MODEL=claude-sonnet-4-20250514
