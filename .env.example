# DataNova 环境配置
# 复制此文件为 .env 并填入实际值

# 加密密钥 (必须32字节，用于加密数据源密码)
DATANOVA_ENCRYPTION_KEY=datanova-default-key-32b!

# 数据目录 (默认: ./data)
# DATANOVA_DIR=./data

# Server 端口 (默认: 3000)
# PORT=3000

# LLM 提供商 API Key (至少配置一个)
OPENAI_API_KEY=sk-your-openai-key
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# 默认 LLM 配置
# DATANOVA_PROVIDER=openai
# DATANOVA_MODEL=gpt-4o
